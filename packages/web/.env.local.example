# Anthropic — required for the chat agent
ANTHROPIC_API_KEY=

# WalletConnect — get a free projectId at https://cloud.reown.com (formerly walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC — defaults to public Ankr if not set, but rate-limited.
# Use Alchemy/Infura for the live demo.
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# Smart account address that the agent operates on Sepolia.
# TODO(contracts): replace with the real ENSFirewallAccount address once aleregex deploys it.
NEXT_PUBLIC_AGENT_SMART_ACCOUNT_ADDRESS=0x000000000000000000000000000000000000dEaD

# Agent ENS — what the agent identifies itself as.
NEXT_PUBLIC_AGENT_ENS=demo-agent.ensfirewall.eth
