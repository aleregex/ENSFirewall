{
    "name": "ensfirewall",
    "version": "0.1.0",
    "private": true,
    "description": "Decentralized firewall for AI agents. Security policies live in ENS, enforced onchain by smart accounts.",
    "packageManager": "pnpm@9.12.0",
    "scripts": {
      "build": "turbo run build",
      "dev": "turbo run dev",
      "lint": "turbo run lint",
      "test": "turbo run test",
      "clean": "turbo run clean && rm -rf node_modules",
      "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
    },
    "devDependencies": {
      "turbo": "^2.3.0",
      "prettier": "^3.4.2",
      "typescript": "^5.7.2"
    },
    "engines": {
      "node": ">=20.0.0",
      "pnpm": ">=9.0.0"
    }
  }